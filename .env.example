# Wellflow — main AI provider (OpenAI-compatible)
WELLFLOW_API_KEY=wf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — for free-tier and fallback models
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://omnichat:omnichat@localhost:5432/omnichat?schema=public

# Redis (caching / rate limiting)
REDIS_URL=redis://localhost:6379

# NextAuth v5 (Auth.js). AUTH_* are the canonical names; legacy NEXTAUTH_*
# kept for tooling that still reads them.
AUTH_SECRET=change-me-in-production
AUTH_URL=https://vibeneura.online
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=https://vibeneura.online

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Antilopay payment gateway
ANTILOPAY_PROJECT_ID=
ANTILOPAY_SECRET_ID=
ANTILOPAY_SECRET_KEY=
ANTILOPAY_CALLBACK_KEY=

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile (captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAxxxxxxxxxxxxxxxxxx

# Replicate (image generation)
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public
NEXT_PUBLIC_APP_URL=https://vibeneura.online
