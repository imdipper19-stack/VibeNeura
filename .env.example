# Claude Hub (server-side only, never expose to client)
ANTHROPIC_BASE_URL=https://api.claudehub.fun
ANTHROPIC_AUTH_TOKEN=sk-hub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — for non-Anthropic models (Llama, GPT, etc.)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://omnichat:omnichat@localhost:5432/omnichat?schema=public

# Redis (caching / rate limiting)
REDIS_URL=redis://localhost:6379

# NextAuth v5 (Auth.js). AUTH_* are the canonical names; legacy NEXTAUTH_*
# kept for tooling that still reads them.
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Antilopay payment gateway
ANTILOPAY_PROJECT_ID=
ANTILOPAY_SECRET_KEY=
ANTILOPAY_WEBHOOK_SECRET=

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
