// Prisma schema — OmniChat
// PostgreSQL + pgvector (enabled for future RAG support)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum Role {
  USER
  ADMIN
}

enum PlanTier {
  FREE
  PREMIUM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum TransactionType {
  TOKEN_PACK
  PRO_PASS
  SPEND
  REFUND
  REFERRAL_BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PromoType {
  TOKENS
  PRO_PASS
}

// NextAuth v5 — JWT session strategy.
// We keep our domain User model and link OAuth identities via googleId / telegramId.
model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  name         String?
  avatarUrl    String?
  role         Role      @default(USER)
  plan         PlanTier  @default(FREE)
  banned       Boolean   @default(false)
  tokenBalance Int       @default(10000) // starter free tokens
  proPassUntil DateTime?
  locale       String    @default("ru")

  googleId   String? @unique
  telegramId BigInt? @unique

  passwordHash       String?
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?   @unique
  emailVerifyExpires DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  referralCode String  @unique
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chats        Chat[]
  folders      Folder[]
  transactions Transaction[]
  promoRedemptions PromoRedemption[]
  auditLogs    AuditLog[]
}

model ModelRegistry {
  id                    String   @id @default(cuid())
  slug                  String   @unique // e.g. "claude-opus-4-6"
  displayName           String
  provider              String // "anthropic", "openai", "meta" ...
  description           String?
  tier                  PlanTier @default(FREE)
  supportsVision        Boolean  @default(false)
  supportsFiles         Boolean  @default(false)
  maxContext            Int      @default(128000)
  inputPricePerMTokens  Float    @default(0)
  outputPricePerMTokens Float    @default(0)
  tokenMultiplier       Float    @default(1.0) // billing multiplier vs 1 token
  enabled               Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  chats    Chat[]
  messages Message[]
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats Chat[]

  @@index([userId, sortOrder])
}

model Chat {
  id        String   @id @default(cuid())
  userId    String
  modelId   String
  title     String   @default("New chat")
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  folderId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  model    ModelRegistry @relation(fields: [modelId], references: [id])
  folder   Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([userId, updatedAt(sort: Desc)])
}

model Message {
  id           String      @id @default(cuid())
  chatId       String
  modelId      String?
  role         MessageRole
  content      String // markdown text
  attachments  Json? // [{type, url, name, mimeType, size}]
  inputTokens  Int         @default(0)
  outputTokens Int         @default(0)
  costTokens   Int         @default(0) // tokens deducted from user balance
  createdAt    DateTime    @default(now())

  chat  Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  model ModelRegistry? @relation(fields: [modelId], references: [id])

  @@index([chatId, createdAt])
}

model Transaction {
  id           String            @id @default(cuid())
  userId       String
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  itemId       String? // reference to billing/catalog.ts entry
  amountTokens Int               @default(0)
  amountMoney  Float             @default(0)
  currency     String            @default("RUB")
  provider     String            @default("antilopay")
  providerRef  String?           @unique
  metadata     Json?
  createdAt    DateTime          @default(now())
  completedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  type        PromoType
  value       Int
  maxUses     Int?
  usedCount   Int       @default(0)
  enabled     Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}
